# ═══════════════════════════════════════════════════════════════
# NexusAgent v3.0 — Environment Configuration
# Copy this file to .env and edit. Sensible defaults work out of the box.
# Anything starred (*) is strongly recommended for production.
# ═══════════════════════════════════════════════════════════════

# ── AI Provider ──────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to use Claude, or leave blank to use local Ollama only.
# Get a key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama — required for embeddings, optional for LLM if using Claude
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M
EMBED_MODEL=nomic-embed-text:latest

# ── Auth / Security ──────────────────────────────────────────────
# * JWT signing secret. If unset, a random one is auto-generated at
#   data/.jwt_secret. Set this explicitly in production to keep tokens
#   valid across restarts and across multiple app servers.
JWT_SECRET=

# ── Integrations ─────────────────────────────────────────────────
# Email (for sending invoices, password resets, etc.)
# Get app password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Discord (webhook for alerts)
DISCORD_WEBHOOK_URL=

# Slack (incoming webhook URL for workflow notifications)
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Google Calendar OAuth (optional — enables calendar sync)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must include: http://localhost:8000/api/calendar/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/calendar/oauth/callback

# Public app URL (used in password-reset emails)
APP_BASE_URL=http://localhost:5173

# WhatsApp bridge shared secret. If blank, one is auto-generated at
# data/.whatsapp_secret on first boot. Paste it into whatsapp_bridge/.env
# as NEXUS_WEBHOOK_SECRET, or copy it from Settings → WhatsApp (admin).
WHATSAPP_WEBHOOK_SECRET=

# ── Database ────────────────────────────────────────────────────
DB_PATH=data/nexusagent.db

# ── App Behavior ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ANOMALY_THRESHOLD=0.15
MONITOR_INTERVAL_MINUTES=60
MAX_SQL_RETRIES=3
MAX_REFLECTION_RETRIES=2
TOP_K_RETRIEVAL=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── SQL Safety ───────────────────────────────────────────────────
# Kill any single query that runs longer than this (seconds).
SQL_QUERY_TIMEOUT_SECONDS=30
# Hard cap on rows returned per query (0 = unlimited, not recommended).
SQL_MAX_ROWS=10000
