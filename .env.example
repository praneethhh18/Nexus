# Ollama Settings (required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M
EMBED_MODEL=nomic-embed-text:latest

# Email Settings (optional - leave blank to disable)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Discord Settings (optional - leave blank to use desktop notifications)
DISCORD_WEBHOOK_URL=

# Database
DB_PATH=data/nexusagent.db

# App Settings
LOG_LEVEL=INFO
ANOMALY_THRESHOLD=0.15
MONITOR_INTERVAL_MINUTES=60
MAX_SQL_RETRIES=3
MAX_REFLECTION_RETRIES=2
TOP_K_RETRIEVAL=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
