# ═══════════════════════════════════════════════════════════════
# NexusAgent v2.0 — Environment Configuration
# Copy this to .env and edit as needed. Defaults work out of box.
# ═══════════════════════════════════════════════════════════════

# Ollama Settings (required — models must be pulled first)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M
EMBED_MODEL=nomic-embed-text:latest

# Email Settings (optional — leave blank to disable email sending)
# Get app password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Discord Settings (optional — leave blank for desktop notification fallback)
DISCORD_WEBHOOK_URL=

# Database
DB_PATH=data/nexusagent.db

# App Behavior
LOG_LEVEL=INFO
ANOMALY_THRESHOLD=0.15
MONITOR_INTERVAL_MINUTES=60
MAX_SQL_RETRIES=3
MAX_REFLECTION_RETRIES=2
TOP_K_RETRIEVAL=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
