# Copy to .env and fill in

# URL where the NexusAgent FastAPI backend is running
NEXUS_API_URL=http://localhost:8000

# Shared secret — REQUIRED.
# Get it by opening NexusAgent → Settings → WhatsApp → "Copy bridge secret"
# (admin only). Or from data/.whatsapp_secret on the server.
NEXUS_WEBHOOK_SECRET=

# Where to cache the WhatsApp session after you scan the QR.
# Delete this folder to re-pair a different phone.
WA_AUTH_DIR=./auth

# Baileys log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=warn
